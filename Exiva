function sendDiscordMessage(message, targetWebhook)
    local dataSend = {content = message}
    HTTP.postJSON(targetWebhook, dataSend, function(data, err)
        if err then print("Discord Webhook Error: " .. err) else print("Message sent to Discord") end
    end)
end

local pzcheck = macro(3000, "PZ Check", function()
    queryPZEnemy()
end)

function checkLocation(position)
    for _, loc in ipairs(locations) do
        if math.abs(position.x - loc.x) <= 1 and math.abs(position.y - loc.y) <= 1 then 
            return true 
        end
    end
    return false
end

macro(10, function()
    local myPosition = player:getPosition()
    if checkLocation(myPosition) then
        queryEnemy()
    end
    delay(1100)
end)

function queryPZEnemy()
    -- Zabezpieczenie na pusta liste z Gista
    if #PZexiva == 0 then return end
    currentPZNick = PZexiva[currentPZIndex]
    if currentPZNick then
        say("!where " .. currentPZNick)
    end
    currentPZIndex = currentPZIndex + 1
    if currentPZIndex > #PZexiva then
        CaveBot.setOn()
        pzcheck.setOff()
        currentPZIndex = 1 
        return 
    end
end

function queryEnemy()
    if #enemiesexiva == 0 then return end
    currentNick = enemiesexiva[currentIndex]
    if not currentNick then return end
    say('exiva "' .. currentNick)
    currentIndex = currentIndex + 1
    if currentIndex > #enemiesexiva then
        CaveBot.setOn(true)
        currentIndex = 1 
        return 
    end
end

onLoginAdvice(function(message)
    for _, rootW in pairs(g_ui.getRootWidget():getChildren()) do
        if rootW:getText() == "For Your Information" then
            local body = rootW:getChildByIndex(1)
            local content = body:getText()
            for _, enemy in ipairs(PZexiva) do
                if content:find(enemy .. " nie znajduje sie w PZ Zone.") then
                    -- Zapobiegaj dublowaniu nickow w tablicy
                    local exists = false
                    for _, exivaNick in ipairs(enemiesexiva) do
                        if exivaNick == enemy then exists = true break end
                    end
                    if not exists then table.insert(enemiesexiva, enemy) end
                end
            end
            rootW:destroy()
        end
    end
end)

function removeEnemyFromList(enemy)
    for index, name in ipairs(enemiesexiva) do
        if name == enemy then
            table.remove(enemiesexiva, index)
            if index <= currentIndex then
                currentIndex = currentIndex - 1
            end
            return
        end
    end
end

