local cavebotDisabledTime = nil
local isCaveBotDisabled = false

macro(1000, function()
    if CaveBot.isOff() and not isCaveBotDisabled then
        isCaveBotDisabled = true
        cavebotDisabledTime = os.time()
    elseif not CaveBot.isOff() then
        isCaveBotDisabled = false
        cavebotDisabledTime = nil
    end

    if isCaveBotDisabled and cavebotDisabledTime then
        if os.difftime(os.time(), cavebotDisabledTime) > 360 then
            CaveBot.setOn(true)
            isCaveBotDisabled = false
            cavebotDisabledTime = nil
        end
    end
end)
