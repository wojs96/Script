-- Pobieranie listy z Gista
local function fetchEnemyList()
    modules.corelib.HTTP.get(ENEMY_URL, function(response)
        if not response or string.len(response) < 10 then return end
        local sanitized = response:gsub("\r", ""):gsub("\n", " ")
        local tempEnemies = {}
        for entry in sanitized:gmatch("{[^}]+}") do
            local nick = entry:match('Nick%s*=%s*"([^\"]+)"')
            if nick then
                table.insert(tempEnemies, nick:match("^%s*(.-)%s*$"))
            end
        end
        PZexiva = tempEnemies
        print("[Uniwersalna Exiva] Pobrano liste graczy: " .. #PZexiva)
    end)
end

