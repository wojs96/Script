local currentChannel = 1

onWalk(function(player, newPos, oldPos)
  if player:getName() ~= g_game.getLocalPlayer():getName() then return end
  local playerTile = g_map.getTile(newPos)
  for _, item in ipairs(playerTile:getItems()) do
    if item:getId() == 1722 then
      schedule(500, function()
        local root = g_ui.getRootWidget()
        local channelsWidget = root:recursiveGetChildById("channels")
        if not channelsWidget then return end
        local channels = channelsWidget:getChildren()
        if #channels > 0 then
          channelsWidget:focusChild(channelsWidget:getChildByIndex(currentChannel))
          local function findJoinButtonByLabel(widget)
            if widget:getText() == "Join" then return widget end
            for _, child in ipairs(widget:getChildren()) do
              local result = findJoinButtonByLabel(child)
              if result then return result end
            end
            return nil
          end
          local joinButton = findJoinButtonByLabel(root)
          if not joinButton or not joinButton:isEnabled() then return end
          joinButton:focus()
          joinButton:onClick()
          currentChannel = currentChannel % 3 + 1
        end
      end)
    end
  end
end)

