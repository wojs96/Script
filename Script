        local enemyListTable = {}
        local enemyURL = "https://pastebin.com/raw/11gxpPkc"

        local function loadEnemyListFromURL(callback)
            if not enemyURL or enemyURL == "" then
                if callback then callback("error") end
                return
            end
            local http = modules.corelib.HTTP
            http.get(enemyURL, function(response)
                if not response then
                    if callback then callback("error") end
                    return
                end
                local sanitizedScript = response:gsub("\r\n", ""):gsub("\n", ""):gsub("^%s*,", ""):gsub(",%s*$", ""):gsub("^%s*", ""):gsub("%s*$", "")
                enemyListTable = {}
                for entry in sanitizedScript:gmatch("{[^}]+}") do
                    local nickname = entry:match('Nick = "([^"]+)"')
                    local profesja = entry:match('Vocation = "([^"]+)"')
                    if nickname and profesja then
                        local normalizedNickname = normalizeName(nickname)
                        enemyListTable[normalizedNickname] = {
                            profession = profesja
                        }
                    end
                end
                if callback then callback() end
            end, function(error)
                if callback then callback("error") end
            end)
        end

        local function isLocalEnemy(name)
            if not storage.enemyList or storage.enemyList == "" then return false end
            local enemyList = string.split(storage.enemyList, "\n")
            local normalizedName = normalizeName(name)
            for _, enemyName in ipairs(enemyList) do
                if normalizeName(enemyName) == normalizedName then return true end
            end
            return false
        end

        local function isApiEnemy(name)
            return enemyListTable[normalizeName(name)] ~= nil
        end

        local function isEnemyFromList(name)
            return isLocalEnemy(name) or isApiEnemy(name)
        end

        if enemyURL and enemyURL ~= "" then
            loadEnemyListFromURL()
        end

        local function isMagicProfession(profession)
            local magicProfessions = { "elder druid", "master sorcerer" }
            for _, magicProfession in ipairs(magicProfessions) do
                if profession:lower():find(magicProfession:lower()) then return true end
            end
            return false
        end

        local function getSkullValue(skull)
            if skull >= 0 and skull <= 5 then return skull else return 0 end
        end

        local function isOnScreen(p1, p2)
            return math.abs(p1.x - p2.x) <= 7 and math.abs(p1.y - p2.y) <= 5
        end

        local function distance(p1, p2)
            return math.max(math.abs(p1.x - p2.x), math.abs(p1.y - p2.y))
        end

