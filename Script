		local function smartUnequip(item, sourceContainerId)
			if not item then return end
			if g_game.move(item, backpackSlot, 1) then return end
			if sourceContainerId then
				for _, c in pairs(getContainers()) do
					if c:getContainerItem():getId() == sourceContainerId then
						if g_game.move(item, c:getSlotPosition(c:getItemsCount()), 1) then return end
					end
				end
			end
		end

		local backtrackingSSA = false
		local backtrackingMR = false
		local openedSSA = false
		local openedMR = false

		local function checkBackpacks(targetContainerId, targetItemId, isSSA)
			local mainBp = getBack()
			if mainBp and mainBp:isContainer() then
				local mainOpen = false
				for _, c in pairs(getContainers()) do
					if c:getContainerItem():getId() == mainBp:getId() then mainOpen = true break end
				end
				if not mainOpen then g_game.open(mainBp) return end
			end

			local foundContainer = nil
			for _, container in pairs(getContainers()) do
				local cItem = container:getContainerItem()
				if cItem and cItem:getId() == targetContainerId then foundContainer = container break end
			end

			if foundContainer then
				if isSSA then openedSSA = true else openedMR = true end

				local items = foundContainer:getItems()
				local itemCount = 0
				local foundBackpack = false
				local nextBackpack = nil

				for _, item in ipairs(items) do
					if item:getId() == targetItemId then itemCount = itemCount + 1 end
					if item:isContainer() and item:getId() == targetContainerId then
						foundBackpack = true
						nextBackpack = item
					end
				end

				if isSSA then
					if itemCount >= 1 and foundBackpack and not backtrackingSSA then
						g_game.open(nextBackpack, foundContainer) delay(200)
					elseif itemCount == 0 and foundBackpack then
						backtrackingSSA = true g_game.openParent(foundContainer) delay(200)
					elseif itemCount == 0 and not foundBackpack then
						backtrackingSSA = true g_game.openParent(foundContainer) delay(200)
					end
				else
					if itemCount >= 1 and foundBackpack and not backtrackingMR then
						g_game.open(nextBackpack, foundContainer) delay(200)
					elseif itemCount == 0 and foundBackpack then
						backtrackingMR = true g_game.openParent(foundContainer) delay(200)
					elseif itemCount == 0 and not foundBackpack then
						backtrackingMR = true g_game.openParent(foundContainer) delay(200)
					end
				end
			else
				
				local shouldOpen = false
				if isSSA and not openedSSA then shouldOpen = true end
				if not isSSA and not openedMR then shouldOpen = true end

				if shouldOpen then
					for _, container in pairs(getContainers()) do
						for _, item in ipairs(container:getItems()) do
							if item:isContainer() and item:getId() == targetContainerId then g_game.open(item) return end
						end
					end
				end
			end
		end

