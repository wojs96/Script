local function KILL_EVERYTHING()
    local root = g_ui.getRootWidget()
    if not root then return end
    
    local idsToRemove = {
        "GuildBot_Main_Panel_V15",
        "BlessSetupWindow_Unique",
        "HotkeyProWindow_Unique",
        "GuildBot_Paral_UI_V15",
        "GuildBot_Paral_Label",
        "GuildBot_Overlay_Info",
        "BotSwitch"
    }
    
    for _, id in ipairs(idsToRemove) do
        local widget = root:recursiveGetChildById(id)
        if widget then widget:destroy() end
    end

    if modules.client_topmenu then
        local topMenu = modules.client_topmenu.getTopMenu()
        if topMenu then
            local children = topMenu:getChildren()
            if children then
                for i = #children, 1, -1 do
                    local child = children[i]
                    if child then
                        local id = child:getId()
                        if id and (string.find(id, "GuildBot_Icon") or id == "autoParalRunaIcon" or id == "autoParalBombaIcon") then
                            child:destroy()
                        end
                    end
                end
            end
        end
    end
end

