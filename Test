    local function addGuildMessageToDefault(name, level, text, isBroadcast)
        local lowerText = text:lower()
        for _, prefix in ipairs(ignoredPrefixes) do
            if lowerText:sub(1, #prefix) == prefix then return end
        end
        local color = (isSpecialName(name) or isBroadcast) and "#00FF00" or "#ffa200ff"
        local levelText = level and (" [" .. level .. "]") or ""
        local prefix = isBroadcast and "[BG] " or "[GUILD] "
        local fullText = prefix .. name .. levelText .. ": " .. text
        console.addText(fullText, { color = color }, "Default", "")
        if isSpecialName(name) then
            modules.game_textmessage.displayMessage(17, fullText)
        end
    end

