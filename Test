                switch:setText(s.label)
                switch:setOn(false) 
                
                switch.onClick = function(w)
                    s.macro.toggle() 
                    local newState = s.macro.isOn()
                    if w.setOn then w:setOn(newState) end
                    if w.setChecked then w:setChecked(newState) end
                end
                
                activeWidgets[s.key] = switch
            end
        end
    end

    -- PRZYWRACANIE STANU
    for _, s in ipairs(scriptsList) do
        if s.macro then
            local savedState = config["state" .. s.key]
            if savedState == true then
                s.macro.setOn()
            else
                s.macro.setOff()
            end
            
            local widget = activeWidgets[s.key]
            if widget then
                if savedState == true then
                    if widget.setOn then widget:setOn(true) end
                    if widget.setChecked then widget:setChecked(true) end
                else
                    if widget.setOff then widget:setOff() end
                    if widget.setChecked then widget:setChecked(false) end
                end
            end
        end
    end

