-- ==========================================================
-- FAZA 1: "NULL LOADER" (Symulacja Pustego Skryptu)
-- ==========================================================
-- Ta sekcja wykonuje się natychmiast. Działa jak załadowanie pustego pliku.

-- 1. Zmiana Tokena Globalnego.
-- Stare instancje skryptu (makra, pętle) sprawdzają ten token.
-- Gdy go zmieniamy tutaj, one widzą zmianę i natychmiast przerywają działanie (return).
local BOOT_TOKEN = os.time() .. "_" .. math.random(10000, 99999)
storage.guildBot_ActiveToken = BOOT_TOKEN

-- 2. Funkcja czyszcząca UI (Hard Kill)
local function executeCleanUp()
    local root = g_ui.getRootWidget()
    local map = modules.game_interface.getMapPanel()
    
    -- Lista ID wszystkich elementów stworzonych przez ten skrypt
    local garbageIDs = {
        "GuildBot_Main_Panel_V15",
        "GuildBot_Paral_UI_V15",
        "GuildBot_Guild_Label",
        "GuildBot_Enemy_Label",
        "GuildBot_Paral_Label",
        "BlessSetupWindow_Unique",
        "HotkeyProWindow_Unique"
    }
    
    for _, id in ipairs(garbageIDs) do
        if root then
            local w = root:recursiveGetChildById(id)
            if w then w:destroy() end
        end
        if map then
            local w = map:recursiveGetChildById(id)
            if w then w:destroy() end
        end
    end
end

-- Wykonaj czyszczenie TERAZ.
executeCleanUp()

