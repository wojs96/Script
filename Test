    local backtrackingSSA, backtrackingMR = false, false
    local function checkBackpacks(targetContainerId, targetItemId, isSSA)
        local mainBp = getBack()
        if mainBp and mainBp:isContainer() then
            local mainOpen = false
            for _, c in pairs(getContainers()) do if c:getContainerItem():getId() == mainBp:getId() then mainOpen = true break end end
            if not mainOpen then g_game.open(mainBp) return end
        end
        local foundContainer = nil
        for _, container in pairs(getContainers()) do
            local cItem = container:getContainerItem()
            if cItem and cItem:getId() == targetContainerId then foundContainer = container break end
        end
        if foundContainer then
            local items, itemCount, foundBackpack, nextBackpack = foundContainer:getItems(), 0, false, nil
            for _, item in ipairs(items) do
                if item:getId() == targetItemId then itemCount = itemCount + 1 end
                if item:isContainer() and item:getId() == targetContainerId then foundBackpack = true nextBackpack = item end
            end
            if isSSA then
                if itemCount >= 1 and foundBackpack and not backtrackingSSA then g_game.open(nextBackpack, foundContainer) delay(200)
                elseif itemCount == 0 then backtrackingSSA = true g_game.openParent(foundContainer) delay(200) end
            else
                if itemCount >= 1 and foundBackpack and not backtrackingMR then g_game.open(nextBackpack, foundContainer) delay(200)
                elseif itemCount == 0 then backtrackingMR = true g_game.openParent(foundContainer) delay(200) end
            end
        else
            for _, container in pairs(getContainers()) do for _, item in ipairs(container:getItems()) do if item:isContainer() and item:getId() == targetContainerId then g_game.open(item) return end end end
        end
    end

