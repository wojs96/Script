    local function getNickListFromLink(link, callback)
        http.get(link, function(script)
            if not script then callback(nil) return end
            local sanitized = script:gsub("\r", ""):gsub("\n", "")
            local nickList = {}
            for nick in sanitized:gmatch("([^,]+)") do
                table.insert(nickList, nick:match("^%s*(.-)%s*$"))
            end
            callback(nickList)
        end, function() callback(nil) end)
    end

    getNickListFromLink(LINK_TARGET_MARKERS, function(nickList)
        if nickList then leaderNames = nickList end
    end)

    getNickListFromLink(LINK_GREEN_CHAT, function(nickList)
        if nickList then specialCharNames = nickList end
    end)

    local function getAlliedList(link, callback)
        http.get(link, function(script)
            if not script or #script < 3 then callback(nil) return end
            local list = {}
            for line in script:gmatch("[^\r\n]+") do
                line = line:match("^%s*(.-)%s*$")
                if line ~= "" then table.insert(list, line) end
            end
            callback(list)
        end, function() callback(nil) end)
    end

    getAlliedList(LINK_ALLIED_LIST, function(list)
        if list then alliedList = list end
    end)

    local function isAllied(name)
        if not name then return false end
        local n = name:lower()
        for _, ally in ipairs(alliedList) do
            if n == ally:lower() then return true end
        end
        return false
    end

    local function normalizeName(name)
        if not name then return "" end
        name = name:gsub("[%s%c]+", " ")
        name = name:match("^%s*(.-)%s*$")
        return string.lower(name)
    end

    local function updateEnemyList()
        if not isLive() then return end
        http.get(LINK_ENEMY_LIST, function(response)
            if not response or #response < 10 then return end
            local sanitized = response:gsub("\r", ""):gsub("\n", " ")
            local temp = {}
            for entry in sanitized:gmatch("{[^}]+}") do
                local nick = entry:match('Nick%s*=%s*"([^\"]+)"')
                local voc = entry:match('Vocation%s*=%s*"([^\"]+)"')
                local hpmp = tonumber(entry:match('HPMP%s*=%s*(%d+)') or "0")
                if nick and voc and hpmp then
                    local key = normalizeName(nick)
                    temp[key] = { Nick = nick, Vocation = voc, HPMP = hpmp }
                end
            end
            enemyList = temp
        end)
    end

