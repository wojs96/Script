-- 3. Funkcja czyszcząca (KILLER)
local function KILL_OLD_INTERFACE()
    local root = g_ui.getRootWidget()
    local map = modules.game_interface.getMapPanel()
    
    for _, id in ipairs(UI_GARBAGE_COLLECTOR) do
        if root then
            local w = root:recursiveGetChildById(id)
            if w then w:destroy() end
        end
        if map then
            local w = map:recursiveGetChildById(id)
            if w then w:destroy() end
        end
    end
end

