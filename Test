        return false
    end

    local function applyFriendMark(creature)
        if not creature or creature == g_game.getLocalPlayer() then return end
        creature:setText("\nF", "white")
        creature:showStaticSquare("white")
    end

    local function applyEnemyMark(creature, enemy)
        local hex, colorName = getVocationColor(enemy.Vocation)
        creature:setText("\n" .. formatHPMP(enemy.HPMP), colorName)
        creature:showStaticSquare(hex)
    end

    function processCreatureRecognition(creature)
        if recognizeMacro.isOff() then return end
        if not creature or not creature:isPlayer() then return end

        if applyLeaderMark(creature) then return end

        local key = normalizeName(creature:getName())
        local enemy = enemyList[key]

        if enemy and enemy.isTarget then
            applyTargetMark(creature, enemy)
            return
        end

        if enemy then
            applyEnemyMark(creature, enemy)
            return
        end

        if creature:getEmblem() == 1 or creature:getEmblem() == 4 or isAllied(creature:getName()) then
            applyFriendMark(creature)
            return
        end
    end

