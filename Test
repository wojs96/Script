                local enemy = enemyList[key]

                local iscommander = (normalizeName(creature:getName()) == normalizeName(storage.commander))

                if iscommander then
                    creature:showStaticSquare("green")
                elseif enemy and enemy.isTarget then
                    creature:showStaticSquare("red")
                elseif enemy then
                    local _, colorName = getVocationColor(enemy.Vocation)
                    creature:showStaticSquare(colorName)
