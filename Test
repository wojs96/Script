                if widget then
                    local isWidgetOn = false
                    if widget.isOn then isWidgetOn = widget:isOn() 
                    elseif widget.isChecked then isWidgetOn = widget:isChecked() end
                    
                    if isMacroOn and not isWidgetOn then
