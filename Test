            local showIcon = config["icon" .. s.key]
            local showPanel = config["show" .. s.key]
            
            if showIcon then
                local itemId = config["id" .. s.key] or s.defaultId
                local txt = config["text" .. s.key] or s.defaultText
                local icon = addIcon(s.label, {item = {id = itemId}, text = txt, movable = true}, function(ic)
