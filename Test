    local function smartUnequip(item, sourceContainerId)
        if not item then return end
        if g_game.move(item, backpackSlot, 1) then return end
        if sourceContainerId then
            for _, c in pairs(getContainers()) do if c:getContainerItem():getId() == sourceContainerId then if g_game.move(item, c:getSlotPosition(c:getItemsCount()), 1) then return end end end
