    local function restoreOldTarget()
        if not lastTarget or not lastTarget:isPlayer() then return end

        local key = normalizeName(lastTarget:getName())
        local enemy = enemyList[key]
        if enemy then
            local hex, colorName = getVocationColor(enemy.Vocation)
            lastTarget:setText("\n" .. formatHPMP(enemy.HPMP), colorName)
            lastTarget:showStaticSquare(colorName)
        elseif lastTarget:getEmblem() == 1 or lastTarget:getEmblem() == 4 or isAllied(lastTarget:getName()) then
            lastTarget:setText("\nF", "white")
            lastTarget:showStaticSquare("white")
        else
            lastTarget:setText("", "white")
            lastTarget:hideStaticSquare("")
        end
    end

    local function applyTargetMark(creature, enemy)
        restoreOldTarget()

        lastTarget = creature
        local hpmp = formatHPMP(enemy.HPMP)
        lastTargetText = "\n" .. hpmp .. "\nTARGET"
        lastTargetColor = "red"

        creature:setText(lastTargetText, "red")
        creature:showStaticSquare("red")
    end

    local function applyLeaderMark(creature)
        if not creature or not storage.commander then return false end
        if normalizeName(creature:getName()) == normalizeName(storage.commander) then
            creature:setText("\nL", "green")
            creature:showStaticSquare("green")
            return true
        end
        return false
    end

    local function applyFriendMark(creature)
        if not creature or creature == g_game.getLocalPlayer() then return end
        creature:setText("\nF", "white")
        creature:showStaticSquare("white")
    end

    local function applyEnemyMark(creature, enemy)
        local hex, colorName = getVocationColor(enemy.Vocation)
        creature:setText("\n" .. formatHPMP(enemy.HPMP), colorName)
        creature:showStaticSquare(hex)
    end

    function processCreatureRecognition(creature)
        if recognizeMacro.isOff() then return end
        if not creature or not creature:isPlayer() then return end

        if applyLeaderMark(creature) then return end

        local key = normalizeName(creature:getName())
        local enemy = enemyList[key]

        if enemy and enemy.isTarget then
            applyTargetMark(creature, enemy)
            return
        end

        if enemy then
            applyEnemyMark(creature, enemy)
            return
        end

        if creature:getEmblem() == 1 or creature:getEmblem() == 4 or isAllied(creature:getName()) then
            applyFriendMark(creature)
            return
        end
    end

