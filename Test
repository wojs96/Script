    local _original_macro = macro
    macro = function(delay, funcOrName, func)
        local callback = func
        if type(funcOrName) == "function" then callback = funcOrName end
        
        local protectedCallback = function()
            if not amIAlive() then return end -- ZABIJ MACRO JEŚLI STARE
            if callback then callback() end
        end

        if type(funcOrName) == "string" then
            return _original_macro(delay, funcOrName, protectedCallback)
        else
            return _original_macro(delay, protectedCallback)
        end
    end

    local _original_onTalk = onTalk
    onTalk = function(callback)
        if _original_onTalk then
            _original_onTalk(function(...)
                if not amIAlive() then return end
                return callback(...)
            end)
        end
    end

